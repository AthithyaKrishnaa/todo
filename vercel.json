{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/home",
      "dest": "/home/home.html"
    },
    {
      "src": "/login",
      "dest": "/login/index.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
